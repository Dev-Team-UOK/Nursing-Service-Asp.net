@using Nursing_Service.Application.Services.PatinetNeedService.Query.GetPatientNeedServices
@model List<GetPatientNeedServiceResultDTO>
@{
    Layout = "_AdminDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">لیست درخواست‌ها</h2>
        <span class="page-subtitle">مشاهده تمامی درخواست‌های ثبت‌شده در سیستم</span>
    </div>
    <a class="btn-primary-custom" href="/PatientNeedServices/Create-PatientNeedService">
        <i class="bi bi-plus-lg"></i>
        <span>ثبت درخواست جدید</span>
    </a>
</div>

<div class="card-custom">
    <div class="card-body-custom p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover">
                <thead>
                    <tr>
                        <th>شناسه</th>
                        <th>تاریخ ثبت</th>
                        <th>بیمار</th>
                        <th>پرستار</th>
                        <th>سوپروایزر مربوطه</th>
                        <th>نوع سرویس</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var request in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@request.Id</span></td>
                                <td dir="ltr" class="text-end text-muted small"><i class="bi bi-calendar3 me-1"></i> @request.ServiceDateTime</td>
                                <td class="fw-bold">@request.PatientFullName</td>
                                <td><i class="bi bi-person-heart text-primary me-1"></i> @request.NurseFullName</td>
                                <td><i class="bi bi-person-badge text-warning me-1"></i> @request.SuperVisorFullName</td>
                                <td><span class="badge bg-info text-dark">@request.ServiceName</span></td>
                                <td>
                                    <a class="action-btn btn-edit" href="/PatientNeedServices/Edit-PatientNeedService?id=@request.Id" title="ویرایش"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn btn-delete" href="/PatientNeedServices/Delete-PatientNeedService?id=@request.Id" title="حذف"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">هیچ درخواستی یافت نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
