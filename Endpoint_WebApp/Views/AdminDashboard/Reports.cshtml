@using Endpoint_WebApp.Models.ViewModels.AdminDashboard
@model ReportsViewModel
@{
    Layout = "_AdminDashboard_Layout";
    var totalNurses = Model.NumberOfNurses;
    var totalPatients = Model.NumberOfPatients;
    var totalServices = Model.NumberOfServices;
    var lastMonthServices = Model.NumberOfPNSInThisMonth;
}

<div class="page-header">
    <div>
        <h2 class="page-title">گزارشات آماری</h2>
        <span class="page-subtitle">خلاصه وضعیت سیستم در یک نگاه</span>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- کارت پرستاران -->
    <div class="col-md-6 col-lg-3">
        <div class="card-custom h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #eff6ff 0%, #ffffff 100%);">
            <div class="card-body p-4 d-flex align-items-center gap-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-primary bg-primary bg-opacity-10" style="width: 64px; height: 64px;">
                    <i class="bi bi-heart-pulse-fill fs-2"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-bold">کل پرستاران</h6>
                    <h3 class="mb-0 fw-bold text-dark">@totalNurses</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- کارت بیماران -->
    <div class="col-md-6 col-lg-3">
        <div class="card-custom h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 100%);">
            <div class="card-body p-4 d-flex align-items-center gap-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-success bg-success bg-opacity-10" style="width: 64px; height: 64px;">
                    <i class="bi bi-person-wheelchair fs-2"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-bold">کل بیماران</h6>
                    <h3 class="mb-0 fw-bold text-dark">@totalPatients</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- کارت سرویس‌ها -->
    <div class="col-md-6 col-lg-3">
        <div class="card-custom h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #fffbeb 0%, #ffffff 100%);">
            <div class="card-body p-4 d-flex align-items-center gap-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-warning bg-warning bg-opacity-10" style="width: 64px; height: 64px;">
                    <i class="bi bi-clipboard2-pulse fs-2"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-bold">تعداد سرویس‌ها</h6>
                    <h3 class="mb-0 fw-bold text-dark">@totalServices</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- خدمات انجام شده -->
    <div class="col-md-6 col-lg-3">
        <div class="card-custom h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #ccfbf1 0%, #ffffff 100%);">
            <div class="card-body p-4 d-flex align-items-center gap-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-teal bg-teal bg-opacity-10" style="width: 64px; height: 64px; color: var(--primary-color);">
                    <i class="bi bi-calendar2-check-fill fs-2"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 fw-bold">درخواست‌های ماه جاری</h6>
                    <h3 class="mb-0 fw-bold text-dark">@lastMonthServices</h3>
                </div>
            </div>
        </div>
    </div>
</div>
