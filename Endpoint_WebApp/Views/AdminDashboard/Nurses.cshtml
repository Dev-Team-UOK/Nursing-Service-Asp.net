@using Nursing_Service.Common.Consts
@using Nursing_Service.Application.Services.Nurse.Query.GetNurses
@model List<GetNurseResultDTO>
@{
    Layout = "_AdminDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">لیست پرستاران</h2>
        <span class="page-subtitle">مدیریت اطلاعات و سوپروایزر پرستاران</span>
    </div>
    <a class="btn-primary-custom" href="/Nurses/Create-Nurse">
        <i class="bi bi-plus-lg"></i>
        <span>افزودن پرستار جدید</span>
    </a>
</div>

<div class="card-custom">
    <div class="card-body-custom p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover">
                <thead>
                    <tr>
                        <th>نام کاربری</th>
                        <th>نام و نام خانوادگی</th>
                        <th>شماره پرستاری</th>
                        <th>سابقه (سال)</th>
                        <th>تلفن همراه</th>
                        <th>سوپروایزر</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var nurse in Model)
                        {
                            <tr>
                                <td>@nurse.UserName</td>
                                <td class="fw-bold">@nurse.FirstName @nurse.LastName</td>
                                <td><span class="badge bg-secondary">@nurse.NurseNumber</span></td>
                                <td>@nurse.WorkHistoryInYear</td>
                                <td dir="ltr" class="text-end">@nurse.PhoneNumber</td>
                                <td>
                                    @if (String.IsNullOrWhiteSpace(nurse.SuperVisorFullName))
                                    {
                                        <select class="form-select form-select-sm supervisor-select" data-nurse-id="@nurse.Id">
                                            <option value="">انتخاب کنید...</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <a href="/SuperVisors/View-SuperVisor?id=@nurse.SuperVisorId" class="text-decoration-none fw-bold text-primary">
                                            <i class="bi bi-person-badge"></i> @nurse.SuperVisorFullName
                                        </a>
                                    }
                                </td>
                                <td>
                                    <a class="action-btn btn-view" href="/Nurses/View-Nurse?id=@nurse.Id" title="مشاهده"><i class="bi bi-eye"></i></a>
                                    <a class="action-btn btn-edit" href="/Nurses/Edit-Nurse?id=@nurse.Id" title="ویرایش"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn btn-delete" href="/Nurses/Delete-Nurse?id=@nurse.Id" title="حذف"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">هیچ پرستاری یافت نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(function () {
            $.getJSON('@Consts.APIHostAddress/api/supervisor/GetAll', function (supervisors) {
                $('.supervisor-select').each(function () {
                    var $select = $(this);
                    supervisors.forEach(function (sup) {
                        $select.append(
                            $('<option>', {
                                value: sup.id,
                                text: sup.fullName || (sup.firstName + ' ' + sup.lastName)
                            })
                        );
                    });
                });
            });

            $(document).on('change', '.supervisor-select', function () {
                var nurseId = $(this).data('nurse-id');
                var supervisorId = $(this).val();
                if (!supervisorId) return;

                var postData = {
                    'Id': nurseId,
                    'supervisorId': supervisorId,
                };

                $.ajax({
                    contentType: 'application/x-www-form-urlencoded',
                    dataType: 'json',
                    type: "POST",
                    url: "/Nurses/Edit-Nurse",
                    data: postData,
                    success: function () {
                        location.reload();
                    },
                    error: function () {
                        alert('خطا در ثبت سوپروایزر!');
                    }
                });
            });
        });
    </script>
}