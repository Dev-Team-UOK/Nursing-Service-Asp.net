@using Nursing_Service.Application.Services.Service.Query.GetServices
@model List<GetServiceResultDTO>
@{
    Layout = "_AdminDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">مدیریت سرویس‌ها</h2>
        <span class="page-subtitle">تعریف و مدیریت خدمات قابل ارائه به بیماران</span>
    </div>
    <a class="btn-primary-custom" href="/Services/Create-Service">
        <i class="bi bi-plus-lg"></i>
        <span>افزودن سرویس جدید</span>
    </a>
</div>

<div class="card-custom">
    <div class="card-body-custom p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover">
                <thead>
                    <tr>
                        <th>شناسه</th>
                        <th>نام سرویس</th>
                        <th>هزینه (تومان)</th>
                        <th>زمان تقریبی انجام (دقیقه)</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var service in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@service.Id</span></td>
                                <td class="fw-bold">@service.Name</td>
                                <td><span class="badge bg-success bg-opacity-10 text-success border border-success">@service.Cost.ToString("N0")</span></td>
                                <td><i class="bi bi-clock me-1 text-muted"></i> @service.MinDuration</td>
                                <td>
                                    <a class="action-btn btn-view" href="/Services/View-Service?id=@service.Id" title="مشاهده"><i class="bi bi-eye"></i></a>
                                    <a class="action-btn btn-edit" href="/Services/Edit-Service?id=@service.Id" title="ویرایش"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn btn-delete" href="/Services/Delete-Service?id=@service.Id" title="حذف"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">هیچ سرویسی یافت نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>