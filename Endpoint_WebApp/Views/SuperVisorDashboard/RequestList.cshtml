@using Nursing_Service.Application.Services.PatinetNeedService.Query.GetPatientNeedServices
@using Nursing_Service.Common.Consts
@model List<GetPatientNeedServiceResultDTO>
@{
    Layout = "_SuperVisorDashboard_Layout";
}
@{
    var superVisorId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="page-header">
    <div>
        <h2 class="page-title">لیست درخواست‌ها</h2>
        <span class="page-subtitle">بررسی درخواست‌ها و ارجاع آن‌ها به پرستاران تحت نظارت</span>
    </div>
</div>

<div class="card-custom">
    <div class="card-body-custom p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover">
                <thead>
                    <tr>
                        <th>شناسه</th>
                        <th>تاریخ و زمان</th>
                        <th>بیمار</th>
                        <th>سرویس</th>
                        <th>پرستار مسئول</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@item.Id</span></td>
                                <td dir="ltr" class="text-end text-muted small"><i class="bi bi-calendar3 me-1"></i> @item.ServiceDateTime.ToString("yyyy/MM/dd HH:mm")</td>
                                <td class="fw-bold">@item.PatientFullName</td>
                                <td><span class="badge bg-info text-dark">@item.ServiceName</span></td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.NurseFullName))
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <select class="form-select form-select-sm nurse-select" data-request-id="@item.Id" style="min-width: 150px;">
                                                <option value="">انتخاب پرستار...</option>
                                            </select>
                                            <button type="button" class="btn btn-sm btn-primary assign-btn" data-request-id="@item.Id">ثبت و ارجاع</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-success"><i class="bi bi-person-check-fill me-1"></i> @item.NurseFullName</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">درخواستی وجود ندارد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        const superVisorId = '@superVisorId';
        let nurses = [];
        
        fetch(`@Consts.APIHostAddress/api/nurse/getAll?superVisorId=${superVisorId}`)
            .then(response => response.json())
            .then(data => {
                nurses = data;
                document.querySelectorAll('.nurse-select').forEach(function (select) {
                    nurses.forEach(function (nurse) {
                        const option = document.createElement('option');
                        option.value = nurse.id;
                        option.text = nurse.firstName + ' ' + nurse.lastName;
                        select.appendChild(option);
                    });
                });
            });

        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('assign-btn')) {
                const requestId = e.target.getAttribute('data-request-id');
                const select = document.querySelector('.nurse-select[data-request-id="' + requestId + '"]');
                const nurseId = select.value;
                if (!nurseId) {
                    alert('لطفا یک پرستار انتخاب کنید.');
                    return;
                }
                
                // Show loading state
                const originalText = e.target.innerHTML;
                e.target.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                e.target.disabled = true;

                fetch('/SuperVisorDashboard/AssignNurse', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() 
                    },
                    body: JSON.stringify({ requestId: requestId, nurseId: nurseId })
                })
                .then(response => {
                    if (response.ok) {
                        alert('پرستار با موفقیت اختصاص یافت.');
                        location.reload();
                    } else {
                        alert('خطا در ثبت پرستار.');
                        e.target.innerHTML = originalText;
                        e.target.disabled = false;
                    }
                })
                .catch(() => {
                    alert('ارتباط با سرور قطع شد.');
                    e.target.innerHTML = originalText;
                    e.target.disabled = false;
                });
            }
        });
    </script>
}
