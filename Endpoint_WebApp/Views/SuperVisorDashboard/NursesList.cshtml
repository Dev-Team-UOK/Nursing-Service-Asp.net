@using Nursing_Service.Application.Services.Nurse.Query.GetNurses
@model List<GetNurseResultDTO>
@{
    Layout = "_SuperVisorDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">لیست پرستاران</h2>
        <span class="page-subtitle">مشاهده لیست پرستاران تحت نظارت شما در این شیفت</span>
    </div>
</div>

<div class="card-custom">
    <div class="card-body-custom p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover">
                <thead>
                    <tr>
                        <th>نام کاربری</th>
                        <th>نام و نام خانوادگی</th>
                        <th>شماره پرستاری</th>
                        <th>شروع همکاری</th>
                        <th>سابقه (سال)</th>
                        <th>تلفن همراه</th>
                        <th>ایمیل</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var nurse in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@nurse.UserName</span></td>
                                <td class="fw-bold">@($"{nurse.FirstName} {nurse.LastName}")</td>
                                <td><span class="badge bg-secondary">@nurse.NurseNumber</span></td>
                                <td class="text-muted small">@nurse.StartWorkingInCompany</td>
                                <td>@(nurse.WorkHistoryInYear?.ToString() ?? "-")</td>
                                <td dir="ltr" class="text-end">@nurse.PhoneNumber</td>
                                <td>@nurse.Email</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">پرستاری یافت نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
