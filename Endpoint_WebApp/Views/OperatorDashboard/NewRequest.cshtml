@{
    Layout = "_OperatorDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">درخواست جدید</h2>
        <span class="page-subtitle">ثبت درخواست خدمات پزشکی یا پرستاری برای بیماران</span>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card-custom">
            <div class="card-body-custom">
                <form autocomplete="off">
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label for="trs-profession" class="form-label">نوع سرویس</label>
                            <select id="trs-profession" class="form-select">
                                <option value="registered-nurse" selected>سرم تراپی</option>
                                <option value="licensed-practical-nurse">واکسناسیون</option>
                                <option value="allied-health">مراقبت از سالمندان</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="trs-specialty" class="form-label">بیمار</label>
                            <select id="trs-specialty" class="form-select">
                                <option value="">انتخاب بیمار...</option>
                                <option>احمد محمودی</option>
                                <option>رضا اکبری</option>
                                <option>ناصر وکیلی</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="service-date" class="form-label">تاریخ و ساعت مراجعه</label>
                            <input type="datetime-local" id="service-date" class="form-control" value="2023-01-01T12:00" />
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label for="trs-location" class="form-label">آدرس محل انجام خدمت</label>
                        <input type="text" id="trs-location" class="form-control" placeholder="آدرس دقیق منزل بیمار">
                    </div>
                    
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary-custom px-5" onclick="event.preventDefault();">
                            <i class="bi bi-save"></i> ثبت درخواست
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>