@{
    Layout = "_OperatorDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">داشبورد اپراتور</h2>
        <span class="page-subtitle">دسترسی سریع به عملیات پرکاربرد</span>
    </div>
</div>

<div class="row g-4 mb-4 justify-content-center mt-2">
    <div class="col-md-5">
        <a href="/OperatorDashboard/NewNurse" class="text-decoration-none">
            <div class="card-custom h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #f5f3ff 0%, #ffffff 100%); transition: transform 0.2s;">
                <div class="card-body p-5 d-flex flex-column align-items-center justify-content-center text-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-primary bg-primary bg-opacity-10" style="width: 80px; height: 80px; color: #7c3aed !important; background-color: #ede9fe !important;">
                        <i class="bi bi-person-plus fs-1"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold text-dark mb-1">ایجاد بیمار جدید</h4>
                        <p class="text-muted small mb-0">ثبت اطلاعات یک بیمار جدید در سامانه</p>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-5">
        <a href="/OperatorDashboard/NewRequest" class="text-decoration-none">
            <div class="card-custom h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #eff6ff 0%, #ffffff 100%); transition: transform 0.2s;">
                <div class="card-body p-5 d-flex flex-column align-items-center justify-content-center text-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-primary bg-primary bg-opacity-10" style="width: 80px; height: 80px;">
                        <i class="bi bi-file-earmark-medical fs-1"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold text-dark mb-1">ایجاد درخواست جدید</h4>
                        <p class="text-muted small mb-0">ثبت درخواست خدمات پرستاری برای بیماران</p>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>
