@{
    Layout = "_OperatorDashboard_Layout";
}

<div class="page-header">
    <div>
        <h2 class="page-title">ثبت بیمار جدید</h2>
        <span class="page-subtitle">وارد کردن اطلاعات بیمار جهت دریافت خدمات پرستاری</span>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card-custom">
            <div class="card-body-custom">
                <form autocomplete="off">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">نام</label>
                            <input type="text" class="form-control" placeholder="مثال: علی">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">نام خانوادگی</label>
                            <input type="text" class="form-control" placeholder="مثال: محمدی">
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">کد ملی</label>
                            <input type="text" class="form-control" placeholder="10 رقمی">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">شماره همراه</label>
                            <input type="tel" class="form-control" placeholder="0912...">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">آدرس سکونت</label>
                        <textarea class="form-control" rows="2" placeholder="آدرس دقیق"></textarea>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="button" class="btn btn-primary-custom px-4">
                            <i class="bi bi-check2-circle"></i> ثبت بیمار
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
