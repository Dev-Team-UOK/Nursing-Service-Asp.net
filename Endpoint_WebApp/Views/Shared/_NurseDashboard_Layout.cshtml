<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>پنل پرستار | پرستار سلامت</title>
    
    <!-- Vazirmatn Font -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" />
    <!-- Bootstrap 5.3 RTL CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    @RenderSection("Styles", required: false)
    <!-- Unified Dashboard Theme -->
    <link rel="stylesheet" href="~/css/DashboardTheme.css">
</head>

<body>
    <!-- سایدبار -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/" class="logo-text">
                <div class="logo-icon">
                    <i class="bi bi-heart-pulse-fill"></i>
                </div>
                <span>پرستار سلامت</span>
            </a>
        </div>
        
        <ul class="sidebar-menu">
            <li>
                <a asp-action="Index" asp-controller="NurseDashboard" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-house-door"></i>
                    <span>صفحه اصلی</span>
                </a>
            </li>
            <li>
                <a asp-action="RequestList" asp-controller="NurseDashboard" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "RequestList" ? "active" : "")">
                    <i class="bi bi-clipboard2-pulse"></i>
                    <span>لیست درخواست‌ها</span>
                </a>
            </li>
            <li>
                <a asp-action="Ability" asp-controller="NurseDashboard" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Ability" ? "active" : "")">
                    <i class="bi bi-star"></i>
                    <span>توانایی‌ها</span>
                </a>
            </li>
        </ul>
        
        <div class="sidebar-footer">
            <div class="profile-card">
                <img src="~/lib/NurseDashboardAssets/img/img_avatar.png" onerror="this.src='/lib/AdminDashboardAssets/img/img_avatar.png'" alt="پروفایل" class="profile-img">
                <div class="profile-info">
                    <span class="name">کاربر پرستار</span>
                    <span class="role">Nurse</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- محتوای اصلی -->
    <div class="main-wrapper">
        <!-- هدر بالای صفحه -->
        <header class="top-header">
            <div class="header-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="جستجو..." disabled>
            </div>
            
            <div class="header-actions">
                <button class="icon-btn" title="پروفایل پرستار">
                    <i class="bi bi-person"></i>
                </button>
                <button class="icon-btn" title="تنظیمات">
                    <i class="bi bi-gear"></i>
                </button>
                <button class="icon-btn" title="اعلان‌ها">
                    <i class="bi bi-bell"></i>
                </button>
                <a asp-action="SignOut" asp-controller="Authentication" class="icon-btn logout" title="خروج از حساب">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </header>

        <!-- بخش کانتنت -->
        <main class="content-area">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>