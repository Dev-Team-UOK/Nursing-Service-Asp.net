@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>پرستار سلامت | مرکز خدمات پرستاری و مراقبت در منزل</title>
    
    <!-- Vazirmatn Persian Font -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" />
    <!-- Bootstrap 5.3 RTL CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- SweetAlert CSS -->
    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <!-- Home Page Custom CSS -->
    <link rel="stylesheet" href="~/css/HomePage.css" />
</head>

<body>

    <!-- هدر ثابت مینیمال -->
    <header class="main-header py-3">
        <div class="container d-flex align-items-center justify-content-between">
            <!-- لوگو و عنوان -->
            <a href="#" class="d-flex align-items-center gap-2 text-decoration-none">
                <div class="rounded-3 bg-teal p-2 d-flex align-items-center justify-content-center text-white" style="background-color: var(--primary-color); width: 40px; height: 40px;">
                    <i class="bi bi-heart-pulse-fill fs-5"></i>
                </div>
                <span class="fw-bold fs-5 text-dark">پرستار سلامت</span>
            </a>

            <!-- منوی اصلی -->
            <nav class="d-none d-lg-flex align-items-center gap-2">
                <a href="#" class="nav-link-custom">خانه</a>
                <a href="#services" class="nav-link-custom">خدمات</a>
                <a href="#about" class="nav-link-custom">درباره ما</a>
                <a href="#team" class="nav-link-custom">تیم متخصص</a>
                <a href="#contact" class="nav-link-custom">تماس با ما</a>
            </nav>

            <!-- اکشن‌ها (تماس و ورود) -->
            <div class="d-flex align-items-center gap-2">
                <a href="tel:02112345678" class="btn btn-outline-secondary btn-sm rounded-pill px-3 d-none d-sm-inline-flex align-items-center gap-2">
                    <i class="bi bi-telephone"></i>
                    <span>۰۲۱-۱۲۳۴۵۶۷۸</span>
                </a>
                <a href="/Authentication/" class="btn btn-primary-custom btn-sm rounded-pill px-3 d-inline-flex align-items-center gap-2">
                    <i class="bi bi-person-lock"></i>
                    <span>ورود پرسنل</span>
                </a>
            </div>
        </div>
    </header>

    <!-- بخش هیرو و فرم ثبت درخواست سریع -->
    <section id="hero-section" class="hero-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <!-- متن معرفی -->
                <div class="col-lg-7">
                    <div class="hero-badge mb-3">
                        <i class="bi bi-shield-check"></i>
                        <span>مرکز مجاز خدمات پرستاری و مراقبت در منزل</span>
                    </div>
                    <h1 class="hero-title mb-4">
                        مراقبت حرفه‌ای و دلسوزانه، <br />
                        <span style="color: var(--primary-color);">در آرامش خانه شما</span>
                    </h1>
                    <p class="fs-5 text-muted mb-4 leading-relaxed" style="max-width: 600px;">
                        ارائه انواع خدمات پرستاری سالمند، کودک، بیماران نیازمند مراقبت ویژه و خدمات بالینی در منزل با کادر مجرب و تاییدشده وزارت بهداشت.
                    </p>

                    <!-- ویژگی‌های سریع -->
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 text-dark font-medium">
                                <i class="bi bi-check-circle-fill text-teal" style="color: var(--primary-color);"></i>
                                <span>اعزام سریع پرستار مجرب</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 text-dark font-medium">
                                <i class="bi bi-check-circle-fill text-teal" style="color: var(--primary-color);"></i>
                                <span>پشتیبانی و نظارت ۲۴ ساعته</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 text-dark font-medium">
                                <i class="bi bi-check-circle-fill text-teal" style="color: var(--primary-color);"></i>
                                <span>مهلت تست و ارزیابی ۴۸ ساعته</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 text-dark font-medium">
                                <i class="bi bi-check-circle-fill text-teal" style="color: var(--primary-color);"></i>
                                <span>پرسنل احراز هویت شده</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- کارت فرم درخواست سریع -->
                <div class="col-lg-5">
                    <div class="card-custom p-4">
                        <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                            <div class="rounded-circle p-2 d-flex align-items-center justify-content-center" style="background: var(--primary-light); color: var(--primary-color); width: 44px; height: 44px;">
                                <i class="bi bi-clipboard-plus fs-5"></i>
                            </div>
                            <div>
                                <h3 class="h5 font-bold mb-0 text-dark">درخواست پرستار در منزل</h3>
                                <small class="text-muted">مشاوره رایگان و هماهنگی سریع</small>
                            </div>
                        </div>

                        <form id="form" onsubmit="event.preventDefault();">
                            <div class="mb-3">
                                <label for="FormFullName" class="form-label font-medium small text-secondary">نام و نام خانوادگی</label>
                                <input type="text" id="FormFullName" class="form-control form-control-custom" placeholder="مثال: علی محمدی" required>
                            </div>

                            <div class="mb-3">
                                <label for="FormPhoneNumber" class="form-label font-medium small text-secondary">شماره موبایل</label>
                                <input type="tel" id="FormPhoneNumber" class="form-control form-control-custom" placeholder="مثال: ۰۹۱۲۱۲۳۴۵۶۷" required>
                            </div>

                            <div class="mb-3">
                                <label for="FormAddress" class="form-label font-medium small text-secondary">آدرس سکونت</label>
                                <input type="text" id="FormAddress" class="form-control form-control-custom" placeholder="شهر / منطقه / آدرس" required>
                            </div>

                            <div class="mb-3">
                                <label for="FormService" class="form-label font-medium small text-secondary">نوع خدمت مورد نیاز</label>
                                <select id="FormService" class="form-select form-control-custom">
                                    <option value="">انتخاب کنید...</option>
                                    <option>پرستاری سالمند</option>
                                    <option>پرستاری کودک</option>
                                    <option>پرستاری بیمار</option>
                                    <option>تزریقات و پانسمان</option>
                                    <option>فیزیوتراپی در منزل</option>
                                </select>
                            </div>

                            <p class="small text-muted mb-3" style="font-size: 0.825rem;">
                                پس از ثبت فرم، کارشناسان ما جهت هماهنگی با شما تماس خواهند گرفت.
                            </p>

                            <button type="submit" class="btn btn-primary-custom w-100 d-flex align-items-center justify-content-center gap-2" onclick="CreateForm()">
                                <i class="bi bi-send-fill"></i>
                                <span>ثبت درخواست و مشاوره</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- بخش خدمات اصلی -->
    <section id="services" class="py-5 bg-white">
        <div class="container py-4">
            <div class="text-center mb-5" style="max-width: 650px; margin: 0 auto;">
                <span class="badge rounded-pill mb-2 px-3 py-2" style="background: var(--primary-light); color: var(--primary-color);">خدمات تخصصی</span>
                <h2 class="fw-bold text-dark mb-3">خدمات پرستاری و مراقبتی ما</h2>
                <p class="text-muted">ارائه طیف وسیعی از خدمات پزشکی و مراقبتی با بالاترین استانداردهای بهداشتی در منزل شما</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="service-card-item">
                        <div class="service-icon-box">
                            <i class="bi bi-person-heart"></i>
                        </div>
                        <h3 class="h5 fw-bold text-dark mb-2">پرستاری سالمند</h3>
                        <p class="text-muted mb-0">مراقبت کامل روزانه و شبانه‌روزی از سالمندان گرامی با احترام، دلسوزی و کادر مجرب.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="service-card-item">
                        <div class="service-icon-box">
                            <i class="bi bi-balloon-heart"></i>
                        </div>
                        <h3 class="h5 fw-bold text-dark mb-2">پرستاری کودک و نوزاد</h3>
                        <p class="text-muted mb-0">نگهداری تخصصی، آموزش و مراقبت بهداشتی نوزادان و کودکان توسط مراقبان آموزش‌دیده.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="service-card-item">
                        <div class="service-icon-box">
                            <i class="bi bi-activity"></i>
                        </div>
                        <h3 class="h5 fw-bold text-dark mb-2">مراقبت از بیمار در منزل</h3>
                        <p class="text-muted mb-0">مراقبت ویژه از بیماران پس از جراحی، بیماران مزمن و نیازمند تجهیزات پزشکی.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="service-card-item">
                        <div class="service-icon-box">
                            <i class="bi bi-bandaid"></i>
                        </div>
                        <h3 class="h5 fw-bold text-dark mb-2">تزریقات و پانسمان</h3>
                        <p class="text-muted mb-0">انجام انواع خدمات بالینی، سرم‌تراپی، تعویض پانسمان زخم و نمونه‌گیری در منزل.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="service-card-item">
                        <div class="service-icon-box">
                            <i class="bi bi-person-walking"></i>
                        </div>
                        <h3 class="h5 fw-bold text-dark mb-2">فیزیوتراپی و توانبخشی</h3>
                        <p class="text-muted mb-0">خدمات فیزیوتراپی تخصصی و حرکات اصلاحی جهت بهبود سریع‌تر بیمار در محیط منزل.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="service-card-item">
                        <div class="service-icon-box">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <h3 class="h5 fw-bold text-dark mb-2">همراه بیمار در بیمارستان</h3>
                        <p class="text-muted mb-0">اعزام نیروهای مجرب جهت همراهی و مراقبت ۲۴ ساعته از بیمار در تمامی بیمارستان‌ها.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- آمار و سوابق -->
    <section id="records" class="py-5" style="background-color: var(--bg-light);">
        <div class="container py-4">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-number">۲۷,۸۳۰+</div>
                        <div class="fw-bold text-dark mt-2">خدمات موفق انجام شده</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-number">+۷۸۰</div>
                        <div class="fw-bold text-dark mt-2">مراقبین فعال و آموزش‌دیده</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-number">+۴۲۰</div>
                        <div class="fw-bold text-dark mt-2">پرستاران کارشناس و متخصص</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- چرا پرستار سلامت (About Us) -->
    <section id="about" class="py-5 bg-white">
        <div class="container py-4">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <span class="badge rounded-pill mb-2 px-3 py-2" style="background: var(--primary-light); color: var(--primary-color);">مزایای انتخاب ما</span>
                    <h2 class="fw-bold text-dark mb-4">چرا خدمات پرستاری خود را به پرستار سلامت بسپارید؟</h2>
                    <p class="text-muted mb-4">
                        مرکز خدمات پرستاری پرستار سلامت با اخذ مجوز رسمی از وزارت بهداشت، درمان و آموزش پزشکی و تکیه بر سال‌ها تجربه، خدماتی شایسته و ایمن را در محیط امن منزل ارائه می‌دهد.
                    </p>

                    <div class="d-flex flex-column gap-4">
                        <div class="feature-box">
                            <div class="feature-icon">
                                <i class="bi bi-award"></i>
                            </div>
                            <div>
                                <h3 class="h6 fw-bold text-dark mb-1">تجربه و تخصص بالای کادر</h3>
                                <p class="text-muted small mb-0">تمامی پرستاران دارای مدارک رسمی و گزینش‌های تخصصی اخلاقی و حرفه‌ای هستند.</p>
                            </div>
                        </div>

                        <div class="feature-box">
                            <div class="feature-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div>
                                <h3 class="h6 fw-bold text-dark mb-1">تضمین اعتماد و احراز هویت</h3>
                                <p class="text-muted small mb-0">اعتمادسازی کامل با دریافت وثایق قانونی و استعلام عدم سوء‌پیشینه تمام نیروها.</p>
                            </div>
                        </div>

                        <div class="feature-box">
                            <div class="feature-icon">
                                <i class="bi bi-arrow-repeat"></i>
                            </div>
                            <div>
                                <h3 class="h6 fw-bold text-dark mb-1">امکان تست و تعویض پرسنل</h3>
                                <p class="text-muted small mb-0">دوره آزمایشی ۲۴ تا ۴۸ ساعته با امکان تعویض پرستار در صورت عدم رضایت کارفرما.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="p-4 rounded-4 bg-teal-subtle text-center" style="background: radial-gradient(circle, rgba(204,251,241,0.6) 0%, rgba(241,245,249,0.8) 100%); border: 1px solid #e2e8f0;">
                        <i class="bi bi-hospital fs-1" style="color: var(--primary-color);"></i>
                        <h3 class="h4 fw-bold text-dark mt-3 mb-2">پشتیبانی و پاسخگویی ۲۴/۷</h3>
                        <p class="text-muted mb-4">کارشناسان ما در تمامی روزهای هفته و ایام تعطیل آماده ارائه مشاوره و پشتیبانی می‌باشند.</p>
                        <a href="tel:02112345678" class="btn btn-primary-custom rounded-pill px-4 d-inline-flex align-items-center gap-2">
                            <i class="bi bi-telephone-outbound"></i>
                            <span>تماس با کارشناس پشتیبانی</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- تیم متخصص ما -->
    <section id="team" class="py-5" style="background-color: var(--bg-light);">
        <div class="container py-4">
            <div class="d-flex align-items-end justify-content-between mb-4">
                <div>
                    <span class="badge rounded-pill mb-2 px-3 py-2" style="background: var(--primary-light); color: var(--primary-color);">کادر درمان</span>
                    <h2 class="fw-bold text-dark mb-0">تیم متخصصین و سوپروایزرها</h2>
                </div>
                <div class="d-flex gap-2">
                    <button id="team-scroll-prev" class="scroll-btn" aria-label="قبلی">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    <button id="team-scroll-next" class="scroll-btn" aria-label="بعدی">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>
            </div>

            <div id="team-members" class="team-scroll-container">
                <div class="team-card">
                    <img src="~/lib/HomePageImages/image/qoraishi.jpg" alt="مریم حسینی" class="team-avatar" />
                    <h3 class="h6 fw-bold text-dark mb-1">مریم حسینی</h3>
                    <p class="small text-muted mb-0">پرستار سالمند (۱۰ سال سابقه)</p>
                </div>
                <div class="team-card">
                    <img src="~/lib/HomePageImages/image/bradpitt.jpg" alt="علی رضایی" class="team-avatar" />
                    <h3 class="h6 fw-bold text-dark mb-1">علی رضایی</h3>
                    <p class="small text-muted mb-0">مراقب کودک و نوزاد</p>
                </div>
                <div class="team-card">
                    <img src="~/lib/HomePageImages/image/the rock.jpg" alt="علی احمدی" class="team-avatar" />
                    <h3 class="h6 fw-bold text-dark mb-1">دکتر علی احمدی</h3>
                    <p class="small text-muted mb-0">متخصص قلب و عروق</p>
                </div>
                <div class="team-card">
                    <img src="~/lib/HomePageImages/image/Angelina.jpg" alt="نازنین محمدی" class="team-avatar" />
                    <h3 class="h6 fw-bold text-dark mb-1">نازنین محمدی</h3>
                    <p class="small text-muted mb-0">پرستار تزریقات و خدمات بالینی</p>
                </div>
                <div class="team-card">
                    <img src="~/lib/HomePageImages/image/sofia.jpg" alt="مهلا سبحانی" class="team-avatar" />
                    <h3 class="h6 fw-bold text-dark mb-1">مهلا سبحانی</h3>
                    <p class="small text-muted mb-0">سوپروایزر ارشد خدمات</p>
                </div>
                <div class="team-card">
                    <img src="~/lib/HomePageImages/image/Scarlett_Johansson-8588.jpg" alt="ایلیا قربانی" class="team-avatar" />
                    <h3 class="h6 fw-bold text-dark mb-1">ایلیا قربانی</h3>
                    <p class="small text-muted mb-0">سوپروایزر کشیک</p>
                </div>
            </div>
        </div>
    </section>

    <!-- فوتر مینیمال -->
    <footer id="contact" class="site-footer">
        <div class="container">
            <div class="row g-4 mb-5">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="rounded-3 p-2 d-flex align-items-center justify-content-center text-white" style="background-color: var(--primary-color); width: 36px; height: 36px;">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                        <span class="fw-bold fs-5 text-white">پرستار سلامت</span>
                    </div>
                    <p class="small text-secondary mb-4 leading-relaxed">
                        مرکز خدمات پرستاری پرستار سلامت با مجوز رسمی از وزارت بهداشت، خدمات خود را به صورت شبانه‌روزی در تمامی ایام سال ارائه می‌دهد.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="https://instagram.com" class="text-secondary fs-5 footer-link"><i class="bi bi-instagram"></i></a>
                        <a href="https://linkedin.com" class="text-secondary fs-5 footer-link"><i class="bi bi-linkedin"></i></a>
                        <a href="https://telegram.org" class="text-secondary fs-5 footer-link"><i class="bi bi-telegram"></i></a>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <h4 class="footer-heading">خدمات اصلی</h4>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a href="#services" class="footer-link">پرستار سالمند در منزل</a></li>
                        <li><a href="#services" class="footer-link">پرستار کودک و نوزاد</a></li>
                        <li><a href="#services" class="footer-link">پرستار بیمار و مراقبت ویژه</a></li>
                        <li><a href="#services" class="footer-link">تزریقات و پانسمان در منزل</a></li>
                        <li><a href="#services" class="footer-link">فیزیوتراپی و توانبخشی</a></li>
                    </ul>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <h4 class="footer-heading">ارتباط با ما</h4>
                    <ul class="list-unstyled d-flex flex-column gap-3 small text-secondary">
                        <li class="d-flex align-items-start gap-2">
                            <i class="bi bi-geo-alt text-teal" style="color: var(--primary-color);"></i>
                            <span>سعادت آباد، سرو غربی، نبش خیابان بخشایش، ساختمان پزشکان سرو</span>
                        </li>
